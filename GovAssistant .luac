						slot38_a6746 = true
					else
						print("Проверка наличия обновлений прошла успешно. Новых версий не обнаружено.")
					end

					os.remove("moonloader\\government\\version.ini")
				end
			end))
		end
	end))

	if sampGetPlayerIdByCharHandle(playerPed) then
